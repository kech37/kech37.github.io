---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Carlos Pinho — Senior Software Engineer',
  description = 'Carlos Pinho. Senior software engineer from Coimbra, Portugal. C#, .NET, and the backend systems in between.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,700&family=IBM+Plex+Mono:ital,wght@0,400;0,500;1,400&family=Instrument+Sans:wght@400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>
